[global]
    frame_width = 2
    frame_color = "#928374"
    separator_color = "frame"

    font = Cascadia Mono 9
    format = "<b>%s</b>\n%b"
    alignment = left

[urgency_low]
    background = "#fbf1c7"
    foreground = "#a89984"
    frame_color = "#928374"
    timeout = 10

[urgency_normal]
    background = "#ebdbb2"
    foreground = "#3c3836"
    frame_color = "#928374"
    timeout = 10

[urgency_critical]
    background = "#fbf1c7"
    foreground = "#cc241d"
    frame_color = "#cc241d"
    timeout = 0